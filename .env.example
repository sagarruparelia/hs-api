# MongoDB
MONGODB_URI=mongodb://localhost:27017/hsapi
MONGODB_DATABASE=hsapi

# AWS
AWS_REGION=us-east-1
HEALTHLAKE_ENDPOINT=https://healthlake.us-east-1.amazonaws.com/datastore/<datastore-id>/r4/
S3_BUCKET=healthsafe-shl-us-east-1

# Security
ENCRYPTION_KEY=your-32-byte-encryption-key-here
# Optional: JWT validation at app layer (primary auth is via API gateway X-Consumer-Id header).
# When set, Spring fetches JWKS from {issuerUri}/.well-known/openid-configuration.
# Leave empty to rely solely on gateway authentication.
OAUTH2_ISSUER_URI=

# Application
APP_BASE_URL=http://localhost:8080
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Development toggles
GRAPHIQL_ENABLED=false
HEALTH_DETAILS=never
